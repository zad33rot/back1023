generator client {
  provider = "prisma-client-js"
  output = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String    @unique
  password     String   
  createAt     DateTime  @default(now())
  posts        Post[]
  sessions     Session[]
}

model Session {
  id           Int      @id @default(autoincrement())
  userId       Int
  refreshToken String   @unique
  device       String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id         Int      @id @default(autoincrement())
  title     String    
  content   String?
  authorId  Int
  author    User @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(uuid())
  kind      String   // Будет хранить тип сообщения: "user" (от человека) или "system" (системное)
  room      String   // Название комнаты чата
  author    String   // Никнейм отправителя
  text      String   // Текст сообщения
  createdAt DateTime @default(now()) // Время отправки
}